#!/bin/sh
set -e

if [ -n "$GITEA_ADMIN_PASSWORD" ]; then
    export GITEA_ADMIN_PASSWORD
fi

if [ -n "$GITEA_SSH_PORT" ]; then
    if [ "$GITEA_SSH_PORT" = "0" ]; then
        sed -i "s/^SSH_PORT = .*/SSH_PORT = -1/" /data/gitea/conf/app.ini 2>/dev/null || true
    else
        sed -i "s/^SSH_PORT = .*/SSH_PORT = $GITEA_SSH_PORT/" /data/gitea/conf/app.ini 2>/dev/null || true
    fi
fi

if [ -n "$GITEA_ROOT_URL" ]; then
    sed -i "s|^ROOT_URL = .*|ROOT_URL = $GITEA_ROOT_URL|" /data/gitea/conf/app.ini 2>/dev/null || true
fi

exec /usr/bin/gitea web --config /data/gitea/conf/app.ini
