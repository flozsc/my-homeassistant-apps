#!/bin/execlineb -P
# S6 initialization for non-root containers
# Configure services without privileged operations

importas -u S6_BEHAVIOUR_IF_STAGE2_FAILS 2
importas -u S6_CMD_WAIT_FOR_SERVICES_MAXTIME 0

# Set up environment for non-root operation
background {
  s6-applyuidgid -u ${USER_UID:-1000} -g ${USER_GID:-1000}
  s6-setuidgid ${USER_UID:-1000}
}
