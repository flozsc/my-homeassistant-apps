#!/bin/sh

# MyGit S6 Service Run Script
# Simple and robust approach that works in Home Assistant

# Set basic shell options for robustness
set -e

# Use environment variables that Home Assistant sets via the add-on system
# These are automatically available when init: true is set in config.yaml
HTTP_PORT=${HTTP_PORT:-3000}
ADMIN_USERNAME=${ADMIN_USERNAME:-admin}
REPO_STORAGE=${REPO_STORAGE:-/data/repos}

# Password handling - only set if explicitly configured
if [ -n "${ADMIN_PASSWORD}" ]; then
    export ADMIN_PASSWORD
fi

# Export required variables
export HTTP_PORT
export ADMIN_USERNAME
export REPO_STORAGE

# Directory setup with error handling
mkdir -p "$REPO_STORAGE" 2>/dev/null || true
chmod 755 "$REPO_STORAGE" 2>/dev/null || true

# Log startup information
echo "[MyGit] Starting v0.0.2 with S6 overlay"
echo "[MyGit] Configuration: Port=$HTTP_PORT, User=$ADMIN_USERNAME, Storage=$REPO_STORAGE"

# Execute the application
exec /usr/local/bin/mygit